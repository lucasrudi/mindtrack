{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"mindtrack\"}[1m])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"mindtrack\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"mindtrack\",status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status}} {{method}} {{uri}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"mindtrack\",area=\"heap\"}",
          "legendFormat": "Used — {{id}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"mindtrack\",area=\"heap\"}",
          "legendFormat": "Max — {{id}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"mindtrack\"}[1m])",
          "legendFormat": "{{action}} {{cause}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"mindtrack\"}",
          "legendFormat": "Live threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"mindtrack\"}",
          "legendFormat": "Daemon threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"mindtrack\"}",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "hikaricp_connections_idle{application=\"mindtrack\"}",
          "legendFormat": "Idle",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "hikaricp_connections_pending{application=\"mindtrack\"}",
          "legendFormat": "Pending",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "hikaricp_connections{application=\"mindtrack\"}",
          "legendFormat": "Total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "DB Query Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(hikaricp_connections_usage_seconds_bucket{application=\"mindtrack\"}[5m]))",
          "legendFormat": "Connection usage p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, rate(hikaricp_connections_creation_seconds_bucket{application=\"mindtrack\"}[5m]))",
          "legendFormat": "Connection creation p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ],
  "refresh": "10s",
