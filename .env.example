# MindTrack Environment Variables
# Copy this file to .env and fill in your values for local development.
# DO NOT commit .env to source control.

# ──────────────────────────────────────────────
# Backend — Spring Boot (application-prod.yml)
# ──────────────────────────────────────────────

# Database (Aurora Serverless v2 MySQL)
DB_URL=jdbc:mysql://your-aurora-cluster.cluster-xyz.us-east-1.rds.amazonaws.com:3306/mindtrack
DB_USERNAME=mindtrack
DB_PASSWORD=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_EXPIRATION_MS=86400000

# Claude AI API
CLAUDE_API_KEY=sk-ant-...

# Frontend URL (used in OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Messaging — Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Messaging — WhatsApp
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Storage (S3 audio bucket)
STORAGE_BUCKET_NAME=mindtrack-dev-audio

# ──────────────────────────────────────────────
# GitHub Actions Secrets (set in repo Settings > Secrets)
# ──────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SONAR_TOKEN=
# SNYK_TOKEN=

# ──────────────────────────────────────────────
# GitHub Actions Variables (set in repo Settings > Variables)
# ──────────────────────────────────────────────
# FRONTEND_BUCKET=mindtrack-prod-frontend
# CLOUDFRONT_DISTRIBUTION_ID=E1234ABCDE
