{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":automergeMinor",
    "schedule:weekends"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Backend (Maven)",
      "matchManagers": ["maven"],
      "groupName": "backend dependencies",
      "commitMessagePrefix": "fix(backend):",
      "addLabels": ["backend"]
    },
    {
      "description": "Frontend (npm)",
      "matchManagers": ["npm"],
      "groupName": "frontend dependencies",
      "commitMessagePrefix": "fix(frontend):",
      "addLabels": ["frontend"]
    },
    {
      "description": "Terraform providers",
      "matchManagers": ["terraform"],
      "groupName": "infra dependencies",
      "commitMessagePrefix": "fix(infra):",
      "addLabels": ["infra"]
    },
    {
      "description": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "commitMessagePrefix": "ci:",
      "automerge": true
    },
    {
      "description": "Major updates require manual merge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["breaking"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
