{
  "name": "mindtrack-frontend",
  "version": "0.5.16",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "cypress run",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@sentry/vue": "^10.42.0",
    "@vueuse/core": "^14.0.0",
    "axios": "^1.15.0",
    "chart.js": "^4.4.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.0",
    "vue-gtag": "^3.7.0",
    "vue-router": "^5.0.0"
  },
  "overrides": {
    "brace-expansion@1.1.12": "1.1.13",
    "brace-expansion@2.0.2": "2.0.3",
    "brace-expansion@5.0.4": "5.0.5",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "picomatch@2.3.1": "2.3.2",
    "picomatch@4.0.3": "4.0.4",
    "yauzl": "3.3.0",
    "editorconfig": {
      "minimatch": "10.2.5"
    }
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.1.1",
    "@types/node": "^24.12.2",
    "@eslint/js": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.0",
    "cypress": "^15.13.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.0.0"
  }
}
