#!/usr/bin/env bash
# commit-msg hook: validates that commit messages follow Conventional Commits format.
# Format: <type>[(<scope>)]: <description>
# Link issues in the PR body with "Closes #N" — not in the commit title.

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits, revert commits, and fixup/squash commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge |Revert |fixup! |squash! )"; then
    exit 0
fi

# Skip release-please automated commits
if echo "$COMMIT_MSG" | grep -qE "^chore\(release\)"; then
    exit 0
fi

# Validate Conventional Commits format
if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|chore|docs|test|refactor|ci|infra|style|perf|build)(\([^)]+\))?: .+"; then
    echo ""
    echo "!! Commit message does not follow the required format."
    echo ""
    echo "   Expected: <type>[(<scope>)]: <description>"
    echo "   Examples:"
    echo "     feat(auth): add JWT token versioning"
    echo "     fix(security): resolve SonarCloud findings"
    echo "     chore: update dependencies"
    echo ""
    echo "   Link issues in the PR body: Closes #N"
    echo ""
    echo "   Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi

exit 0
