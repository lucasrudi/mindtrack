#!/usr/bin/env bash
set -e

echo "=== Pre-push checks ==="

# Backend tests
if [ -d "backend" ]; then
    echo ">> Running backend tests..."
    cd backend
    mvn test -q
    cd ..
    echo ">> Backend tests passed."
fi

# Frontend lint + tests
if [ -d "frontend" ] && [ -f "frontend/package.json" ]; then
    echo ">> Running frontend lint..."
    cd frontend
    npm run lint
    echo ">> Running frontend tests..."
    npm run test:unit -- --run
    cd ..
    echo ">> Frontend checks passed."
fi

# Terraform checks
if [ -d "infra" ]; then
    echo ">> Running Terraform checks..."
    terraform -chdir=infra fmt -check -recursive
    terraform -chdir=infra validate
    if command -v tflint &> /dev/null; then
        tflint --recursive --chdir=infra --minimum-failure-severity=error
    fi
    if command -v tfsec &> /dev/null; then
        tfsec infra/ --soft-fail
    fi
    echo ">> Terraform checks passed."
fi

# Snyk vulnerability scan
if command -v snyk &> /dev/null; then
    echo ">> Running Snyk vulnerability scan..."

    if [ -d "backend" ]; then
        echo "   Scanning backend dependencies..."
        set +e
        snyk test --file=backend/pom.xml --severity-threshold=high 2>&1
        snyk_exit=$?
        set -e
        if [ $snyk_exit -eq 1 ]; then
            echo "!! Snyk found high/critical vulnerabilities in backend. Fix them before pushing."
            exit 1
        elif [ $snyk_exit -eq 2 ]; then
            echo "!! Snyk scan failed (API/config error). Skipping backend scan."
        fi
    fi

    if [ -d "frontend" ] && [ -f "frontend/package.json" ]; then
        echo "   Scanning frontend dependencies..."
        set +e
        snyk test --file=frontend/package.json --severity-threshold=high 2>&1
        snyk_exit=$?
        set -e
        if [ $snyk_exit -eq 1 ]; then
            echo "!! Snyk found high/critical vulnerabilities in frontend. Fix them before pushing."
            exit 1
        elif [ $snyk_exit -eq 2 ]; then
            echo "!! Snyk scan failed (API/config error). Skipping frontend scan."
        fi
    fi

    echo ">> Snyk scan passed."
else
    echo ">> Snyk CLI not installed, skipping vulnerability scan."
    echo "   Install with: npm install -g snyk && snyk auth"
fi

echo "=== All pre-push checks passed ==="
