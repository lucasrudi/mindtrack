#!/usr/bin/env bash
set -e

# Ensure Homebrew Java and Maven are available in non-interactive shells
# (JAVA_HOME is normally set via ~/.zshrc which isn't sourced by git hooks)
if [ -z "$JAVA_HOME" ]; then
    HOMEBREW_JDK="/opt/homebrew/opt/openjdk/libexec/openjdk.jdk/Contents/Home"
    if [ -d "$HOMEBREW_JDK" ]; then
        export JAVA_HOME="$HOMEBREW_JDK"
    fi
fi
export PATH="/opt/homebrew/bin:$PATH"

echo "=== Pre-push checks ==="

# Backend tests
if [ -d "backend" ]; then
    echo ">> Running backend tests..."
    cd backend
    mvn test -q -Djacoco.skip=true
    cd ..
    echo ">> Backend tests passed."
fi

# Frontend lint + tests
if [ -d "frontend" ] && [ -f "frontend/package.json" ]; then
    echo ">> Running frontend lint..."
    cd frontend
    npm run lint
    echo ">> Running frontend tests..."
    npm run test:unit -- --run
    cd ..
    echo ">> Frontend checks passed."
fi

# Terraform checks
if [ -d "infra" ]; then
    echo ">> Running Terraform checks..."
    terraform -chdir=infra fmt -check -recursive
    terraform -chdir=infra validate
    if command -v tflint &> /dev/null; then
        tflint --recursive --chdir=infra --minimum-failure-severity=error
    fi
    if command -v tfsec &> /dev/null; then
        tfsec infra/ --soft-fail
    fi
    echo ">> Terraform checks passed."
fi

echo "=== All pre-push checks passed ==="
